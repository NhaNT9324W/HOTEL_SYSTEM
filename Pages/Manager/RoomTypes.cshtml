@page
@model Hotel_System.Pages.Manager.RoomTypesModel
@{
    ViewData["Title"] = "Room Types Management";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3><i class="bi bi-door-closed"></i> Quản lý Loại Phòng</h3>
    <button class="btn btn-primary" onclick="openCreateModal()">
        <i class="bi bi-plus-circle"></i> Thêm loại phòng
    </button>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover align-middle" id="roomTypeTable">
            <thead class="table-light">
                <tr>
                    <th>Tên loại phòng</th>
                    <th>Sức chứa</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                <!-- JS render vào đây -->
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Thêm/Sửa -->
<div class="modal fade" id="roomTypeModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="modalTitle">Thêm loại phòng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="rtId" />
                <div class="mb-3">
                    <label class="form-label">Tên loại phòng</label>
                    <input class="form-control" id="rtName" placeholder="VD: Deluxe, Standard..." />
                </div>
                <div class="mb-3">
                    <label class="form-label">Mô tả</label>
                    <textarea class="form-control" id="rtDesc" rows="2"></textarea>
                </div>
                <div class="row">
                    <div class="col mb-3">
                        <label class="form-label">Giá cơ bản (VNĐ)</label>
                        <input type="number" class="form-control" id="rtPrice" min="0" />
                    </div>
                    <div class="col mb-3">
                        <label class="form-label">Sức chứa (người)</label>
                        <input type="number" class="form-control" id="rtOccupancy" min="1" />
                    </div>
                </div>
                <div class="mb-3" id="statusWrapper" style="display:none">
                    <label class="form-label">Trạng thái</label>
                    <select class="form-select" id="rtIsActive">
                        <option value="true">Active</option>
                        <option value="false">Inactive</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button class="btn btn-success" onclick="saveRoomType()">
                    <i class="bi bi-check-circle"></i> Lưu
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal View Detail -->
<div class="modal fade" id="roomTypeDetailModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title"><i class="bi bi-eye"></i> Chi tiết loại phòng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="roomTypeDetailBody">
                <!-- render bằng JS -->
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/roomtype.js"></script>
}