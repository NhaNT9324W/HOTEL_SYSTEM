<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hotel System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    @{
        var role = Context.User.FindFirst(
        System.Security.Claims.ClaimTypes.Role)?.Value;
        var fullName = Context.User.FindFirst(
        System.Security.Claims.ClaimTypes.GivenName)?.Value;
        var pageTitle = ViewData["Title"]?.ToString() ?? "Dashboard";
    }

    <!-- ===== SIDEBAR ===== -->
    <div id="sidebar">
        <!-- Brand -->
        <div class="sidebar-brand">
            <div class="d-flex align-items-center gap-2">
                <div style="width:36px;height:36px;background:#0f3460;
                        border-radius:8px;display:flex;align-items:center;
                        justify-content:center;">
                    <i class="bi bi-building text-white"></i>
                </div>
                <div>
                    <h5>Hotel System</h5>
                    <small>Management Portal</small>
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <nav class="mt-2">

            @if (role == "Admin")
            {
                <div class="nav-label">Admin</div>
                <div class="nav-item">
                    <a href="/Admin/Dashboard" class="@(pageTitle == "Dashboard" ? "active" : "")">
                        <i class="bi bi-grid"></i> Dashboard
                    </a>
                </div>
                <div class="nav-item">
                    <a href="/Admin/Accounts" class="@(pageTitle == "Accounts" ? "active" : "")">
                        <i class="bi bi-people"></i> Accounts
                    </a>
                </div>
                <div class="nav-item">
                    <a href="/Admin/HotelInfo" class="@(pageTitle == "Hotel Information" ? "active" : "")">
                        <i class="bi bi-building-gear"></i> Hotel Info
                    </a>
                </div>

                <div class="nav-label">Management</div>
                <div class="nav-item">
                    <a href="/Manager/RoomTypes" class="@(pageTitle == "Room Types" ? "active" : "")">
                        <i class="bi bi-door-closed"></i> Room Types
                    </a>
                </div>
                <div class="nav-item">
                    <a href="/Manager/Rooms" class="@(pageTitle == "Rooms" ? "active" : "")">
                        <i class="bi bi-door-open"></i> Rooms
                    </a>
                </div>
                <div class="nav-item">
                    <a href="/Manager/Services" class="@(pageTitle == "Service Management" ? "active" : "")">
                        <i class="bi bi-gear"></i> Services
                    </a>
                </div>
                <div class="nav-item">
                    <a href="/Manager/Tasks" class="@(pageTitle == "Task Management" ? "active" : "")">
                        <i class="bi bi-clipboard-check"></i> Tasks
                    </a>
                </div>
                <div class="nav-item">
                    <a href="/Manager/Reports" class="@(pageTitle == "Reports" ? "active" : "")">
                        <i class="bi bi-bar-chart"></i> Reports
                    </a>
                </div>
                <div class="nav-item">
                    <a href="/Manager/MaintenanceIssues" class="@(pageTitle == "Maintenance Issues" ? "active" : "")">
                        <i class="bi bi-tools"></i> Maintenance
                    </a>
                </div>

                <div class="nav-label">Operations</div>
                <div class="nav-item">
                    <a href="/Receptionist/Guests" class="@(pageTitle == "Guest Management" ? "active" : "")">
                        <i class="bi bi-person-lines-fill"></i> Guests
                    </a>
                </div>
                <div class="nav-item">
                    <a href="/Receptionist/Reservations" class="@(pageTitle == "Reservation Management" ? "active" : "")">
                        <i class="bi bi-calendar-check"></i> Reservations
                    </a>
                </div>
            }

            @if (role == "HotelManager")
            {
                <div class="nav-label">Overview</div>
                <div class="nav-item">
                    <a href="/Manager/Dashboard" class="@(pageTitle == "Dashboard" ? "active" : "")">
                        <i class="bi bi-grid"></i> Dashboard
                    </a>
                </div>

                <div class="nav-label">Management</div>
                <div class="nav-item">
                    <a href="/Manager/RoomTypes" class="@(pageTitle == "Room Types" ? "active" : "")">
                        <i class="bi bi-door-closed"></i> Room Types
                    </a>
                </div>
                <div class="nav-item">
                    <a href="/Manager/Rooms" class="@(pageTitle == "Rooms" ? "active" : "")">
                        <i class="bi bi-door-open"></i> Rooms
                    </a>
                </div>
                <div class="nav-item">
                    <a href="/Manager/Services" class="@(pageTitle == "Service Management" ? "active" : "")">
                        <i class="bi bi-gear"></i> Services
                    </a>
                </div>
                <div class="nav-item">
                    <a href="/Manager/Tasks" class="@(pageTitle == "Task Management" ? "active" : "")">
                        <i class="bi bi-clipboard-check"></i> Tasks
                    </a>
                </div>
                <div class="nav-item">
                    <a href="/Manager/MaintenanceIssues" class="@(pageTitle == "Maintenance Issues" ? "active" : "")">
                        <i class="bi bi-tools"></i> Maintenance
                    </a>
                </div>

                <div class="nav-label">Reports</div>
                <div class="nav-item">
                    <a href="/Manager/Reports" class="@(pageTitle == "Reports" ? "active" : "")">
                        <i class="bi bi-bar-chart"></i> Reports
                    </a>
                </div>

                <div class="nav-label">Operations</div>
                <div class="nav-item">
                    <a href="/Receptionist/Guests" class="@(pageTitle == "Guest Management" ? "active" : "")">
                        <i class="bi bi-person-lines-fill"></i> Guests
                    </a>
                </div>
                <div class="nav-item">
                    <a href="/Receptionist/Reservations" class="@(pageTitle == "Reservation Management" ? "active" : "")">
                        <i class="bi bi-calendar-check"></i> Reservations
                    </a>
                </div>
            }

            @if (role == "Receptionist")
            {
                <div class="nav-label">Overview</div>
                <div class="nav-item">
                    <a href="/Receptionist/Dashboard" class="@(pageTitle == "Dashboard" ? "active" : "")">
                        <i class="bi bi-grid"></i> Dashboard
                    </a>
                </div>

                <div class="nav-label">Operations</div>
                <div class="nav-item">
                    <a href="/Receptionist/Reservations" class="@(pageTitle == "Reservation Management" ? "active" : "")">
                        <i class="bi bi-calendar-check"></i> Reservations
                    </a>
                </div>
                <div class="nav-item">
                    <a href="/Receptionist/Guests" class="@(pageTitle == "Guest Management" ? "active" : "")">
                        <i class="bi bi-person-lines-fill"></i> Guests
                    </a>
                </div>
            }

            @if (role == "RoomStaff")
            {
                <div class="nav-label">Overview</div>
                <div class="nav-item">
                    <a href="/RoomStaff/Dashboard" class="@(pageTitle == "Dashboard" ? "active" : "")">
                        <i class="bi bi-grid"></i> Dashboard
                    </a>
                </div>

                <div class="nav-label">My Work</div>
                <div class="nav-item">
                    <a href="/RoomStaff/Tasks" class="@(pageTitle == "My Tasks" ? "active" : "")">
                        <i class="bi bi-clipboard-check"></i> My Tasks
                    </a>
                </div>
            }

        </nav>

        <!-- User Info -->
        <div class="sidebar-user">
            <div class="d-flex align-items-center gap-2">
                <div style="width:36px;height:36px;background:#0f3460;border-radius:50%;
                        display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-person text-white"></i>
                </div>
                <div class="flex-grow-1 overflow-hidden">
                    <p class="user-name text-truncate" id="sidebarFullName">@fullName</p>
                    <span class="user-role">@role</span>
                </div>
                <button class="btn-icon" onclick="logout()" title="Logout">
                    <i class="bi bi-box-arrow-right"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- ===== MAIN CONTENT ===== -->
    <div id="main-content">

        <!-- Topbar -->
        <div id="topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="btn-icon d-md-none" onclick="toggleSidebar()">
                    <i class="bi bi-list"></i>
                </button>
                <h6 class="page-title">@pageTitle</h6>
            </div>
            <div class="topbar-actions">
                <div class="dropdown">
                    <button class="btn-icon" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                        <li>
                            <div class="px-3 py-2">
                                <p class="mb-0 fw-semibold" id="topbarFullName">@fullName</p>
                                <small class="text-muted">@role</small>
                            </div>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item" href="#" onclick="openProfileModal()">
                                <i class="bi bi-person me-2"></i> My Profile
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="#"
                               onclick="openChangePasswordModal()">
                                <i class="bi bi-key me-2"></i> Change Password
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item text-danger" href="#" onclick="logout()">
                                <i class="bi bi-box-arrow-right me-2"></i> Logout
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Page Content -->
        <div class="content-wrapper">
            @RenderBody()
        </div>

    </div>

    <!-- ===== PROFILE MODAL ===== -->
    <div class="modal fade" id="profileModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-person-circle"></i> My Profile
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="profileAlert" class="alert d-none"></div>
                    <div class="card bg-light border-0 mb-3">
                        <div class="card-body py-3">
                            <div class="d-flex align-items-center mb-2">
                                <div style="width:48px;height:48px;background:#0f3460;
                                        border-radius:50%;display:flex;
                                        align-items:center;justify-content:center;"
                                     class="me-3">
                                    <i class="bi bi-person text-white fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0" id="profile_display_name"></h6>
                                    <small class="text-muted"
                                           id="profile_display_username"></small>
                                </div>
                            </div>
                            <hr class="my-2" />
                            <div class="row">
                                <div class="col-6">
                                    <small class="text-muted">Role</small>
                                    <div id="profile_display_role"></div>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted">Status</small>
                                    <div id="profile_display_status"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <h6 class="fw-bold mb-3">
                        <i class="bi bi-pencil"></i> Edit Information
                    </h6>
                    <div class="mb-3">
                        <label class="form-label">Full Name <span class="text-danger">*</span></label>
                        <input type="text" id="profile_fullName" class="form-control" />
                        <div id="profile_fullName_error" class="text-danger small"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email <span class="text-danger">*</span></label>
                        <input type="email" id="profile_email" class="form-control" />
                        <div id="profile_email_error" class="text-danger small"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Phone</label>
                        <input type="text" id="profile_phone" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" onclick="submitEditProfile()">
                        Save Changes
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== CHANGE PASSWORD MODAL ===== -->
    <div class="modal fade" id="changePasswordModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title">
                        <i class="bi bi-key"></i> Change Password
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="changePassAlert" class="alert d-none"></div>
                    <div class="mb-3">
                        <label class="form-label">
                            Current Password
                            <span class="text-danger">*</span>
                        </label>
                        <input type="password" id="cp_current" class="form-control" />
                        <div id="cp_current_error" class="text-danger small"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">
                            New Password
                            <span class="text-danger">*</span>
                        </label>
                        <input type="password" id="cp_new" class="form-control"
                               placeholder="Min 6 characters" />
                        <div id="cp_new_error" class="text-danger small"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">
                            Confirm Password
                            <span class="text-danger">*</span>
                        </label>
                        <input type="password" id="cp_confirm" class="form-control" />
                        <div id="cp_confirm_error" class="text-danger small"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-warning" onclick="submitChangePassword()">
                        Change Password
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Toggle sidebar mobile
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('show');
        }

        // Logout
        async function logout() {
            await fetch('/api/auth/logout', { method: 'POST' });
            document.cookie = 'jwt_token=; path=/; max-age=0';
            sessionStorage.clear();
            window.location.href = '/Login';
        }

        // ===== PROFILE =====
        async function openProfileModal() {
            const userId = sessionStorage.getItem('userId');
            const response = await fetch(`/api/accounts/${userId}`);
            const account = await response.json();

            document.getElementById('profile_display_name').textContent = account.fullName;
            document.getElementById('profile_display_username').textContent =
                '@@' + account.username;
            document.getElementById('profile_display_role').innerHTML =
                `<span class="badge bg-info">${getRoleName(account.role)}</span>`;
            document.getElementById('profile_display_status').innerHTML =
                account.status === 0
                    ? '<span class="badge bg-success">Active</span>'
                    : '<span class="badge bg-secondary">Inactive</span>';

            document.getElementById('profile_fullName').value = account.fullName;
            document.getElementById('profile_email').value = account.email;
            document.getElementById('profile_phone').value = account.phone || '';
            document.getElementById('profile_fullName_error').textContent = '';
            document.getElementById('profile_email_error').textContent = '';
            document.getElementById('profileAlert').classList.add('d-none');

            new bootstrap.Modal(document.getElementById('profileModal')).show();
        }

        async function submitEditProfile() {
            const fullName = document.getElementById('profile_fullName').value.trim();
            const email = document.getElementById('profile_email').value.trim();
            const phone = document.getElementById('profile_phone').value.trim();

            let isValid = true;
            if (!fullName) {
                document.getElementById('profile_fullName_error').textContent =
                    'Full name is required';
                isValid = false;
            } else {
                document.getElementById('profile_fullName_error').textContent = '';
            }

            if (!email) {
                document.getElementById('profile_email_error').textContent =
                    'Email is required';
                isValid = false;
            } else {
                document.getElementById('profile_email_error').textContent = '';
            }

            if (!isValid) return;

            const response = await fetch('/api/auth/edit-profile', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ fullName, email, phone })
            });

            const result = await response.json();
            const alertBox = document.getElementById('profileAlert');

            if (response.ok) {
                sessionStorage.setItem('fullName', fullName);
                document.getElementById('sidebarFullName').textContent = fullName;
                document.getElementById('topbarFullName').textContent = fullName;
                document.getElementById('profile_display_name').textContent = fullName;

                alertBox.className = 'alert alert-success';
                alertBox.textContent = result.message;
                alertBox.classList.remove('d-none');
                setTimeout(() => {
                    bootstrap.Modal.getInstance(
                        document.getElementById('profileModal')).hide();
                }, 1500);
            } else {
                alertBox.className = 'alert alert-danger';
                alertBox.textContent = result.message;
                alertBox.classList.remove('d-none');
            }
        }

        // ===== CHANGE PASSWORD =====
        function openChangePasswordModal() {
            document.getElementById('cp_current').value = '';
            document.getElementById('cp_new').value = '';
            document.getElementById('cp_confirm').value = '';
            ['current', 'new', 'confirm'].forEach(f => {
                document.getElementById(`cp_${f}_error`).textContent = '';
            });
            document.getElementById('changePassAlert').classList.add('d-none');
            new bootstrap.Modal(document.getElementById('changePasswordModal')).show();
        }

        async function submitChangePassword() {
            const currentPassword = document.getElementById('cp_current').value.trim();
            const newPassword = document.getElementById('cp_new').value.trim();
            const confirmPassword = document.getElementById('cp_confirm').value.trim();

            let isValid = true;

            if (!currentPassword) {
                document.getElementById('cp_current_error').textContent =
                    'Current password is required';
                isValid = false;
            } else {
                document.getElementById('cp_current_error').textContent = '';
            }

            if (!newPassword || newPassword.length < 6) {
                document.getElementById('cp_new_error').textContent =
                    'Password must be at least 6 characters';
                isValid = false;
            } else {
                document.getElementById('cp_new_error').textContent = '';
            }

            if (!confirmPassword) {
                document.getElementById('cp_confirm_error').textContent =
                    'Please confirm your password';
                isValid = false;
            } else if (newPassword !== confirmPassword) {
                document.getElementById('cp_confirm_error').textContent =
                    'Passwords do not match';
                isValid = false;
            } else {
                document.getElementById('cp_confirm_error').textContent = '';
            }

            if (!isValid) return;

            const response = await fetch('/api/auth/change-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ currentPassword, newPassword, confirmPassword })
            });

            const result = await response.json();
            const alertBox = document.getElementById('changePassAlert');

            if (response.ok) {
                alertBox.className = 'alert alert-success';
                alertBox.textContent = result.message;
                alertBox.classList.remove('d-none');
                setTimeout(() => {
                    bootstrap.Modal.getInstance(
                        document.getElementById('changePasswordModal')).hide();
                }, 1500);
            } else {
                alertBox.className = 'alert alert-danger';
                alertBox.textContent = result.message;
                alertBox.classList.remove('d-none');
            }
        }

        // ===== HELPERS =====
        function getRoleName(role) {
            const roles = ['Admin', 'HotelManager', 'Receptionist', 'RoomStaff'];
            return roles[role] || 'Unknown';
        }
    </script>
</body>
</html>