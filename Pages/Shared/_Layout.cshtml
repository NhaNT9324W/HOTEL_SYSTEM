<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hotel System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Hotel_System.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-page="/Index">
                    <i class="bi bi-building"></i> Hotel System
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-page="/Admin/Accounts">
                                <i class="bi bi-people"></i> Accounts
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-page="/Manager/RoomTypes">
                                <i class="bi bi-door-closed"></i> Room Types
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-page="/Manager/Rooms">
                                <i class="bi bi-door-open"></i> Rooms
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-page="/Admin/HotelInfo">
                                <i class="bi bi-building-gear"></i> Hotel Info
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-page="/Manager/Services">
                                <i class="bi bi-gear"></i> Services
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-page="/Receptionist/Reservations">
                                <i class="bi bi-calendar-check"></i> Reservations
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-page="/Receptionist/Guests">
                                <i class="bi bi-person-lines-fill"></i> Guests
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-page="/Manager/Tasks">
                                <i class="bi bi-clipboard-check"></i> Tasks
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#"
                               data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i>
                                <span id="navFullName"></span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <h6 class="dropdown-header" id="dropdownRole"></h6>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" href="#"
                                       onclick="openProfileModal()">
                                        <i class="bi bi-person"></i> My Profile
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="#"
                                       onclick="openChangePasswordModal()">
                                        <i class="bi bi-key"></i> Change Password
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item text-danger" href="#"
                                       onclick="logout()">
                                        <i class="bi bi-box-arrow-right"></i> Logout
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container">
            &copy; 2026 - Hotel System
        </div>
    </footer>

    <!-- ===== PROFILE MODAL ===== -->
    <div class="modal fade" id="profileModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-person-circle"></i> My Profile
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="profileAlert" class="alert d-none"></div>

                    <!-- Thông tin hiện tại -->
                    <div class="card bg-light mb-3">
                        <div class="card-body py-2">
                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-person-circle fs-1 text-primary me-3"></i>
                                <div>
                                    <h6 class="mb-0" id="profile_display_name"></h6>
                                    <small class="text-muted" id="profile_display_username"></small>
                                </div>
                            </div>
                            <hr class="my-2" />
                            <div class="row">
                                <div class="col-6">
                                    <small class="text-muted">Role</small>
                                    <div id="profile_display_role"></div>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted">Status</small>
                                    <div id="profile_display_status"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Form edit -->
                    <h6 class="fw-bold mb-3">
                        <i class="bi bi-pencil"></i> Edit Information
                    </h6>
                    <div class="mb-3">
                        <label class="form-label">Full Name <span class="text-danger">*</span></label>
                        <input type="text" id="profile_fullName" class="form-control" />
                        <div id="profile_fullName_error" class="text-danger small"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email <span class="text-danger">*</span></label>
                        <input type="email" id="profile_email" class="form-control" />
                        <div id="profile_email_error" class="text-danger small"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Phone</label>
                        <input type="text" id="profile_phone" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" onclick="submitEditProfile()">
                        Save Changes
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== CHANGE PASSWORD MODAL ===== -->
    <div class="modal fade" id="changePasswordModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title">
                        <i class="bi bi-key"></i> Change Password
                    </h5>
                    <button type="button" class="btn-close"
                            data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="changePassAlert" class="alert d-none"></div>
                    <div class="mb-3">
                        <label class="form-label">Current Password <span class="text-danger">*</span></label>
                        <input type="password" id="cp_current" class="form-control" />
                        <div id="cp_current_error" class="text-danger small"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">New Password <span class="text-danger">*</span></label>
                        <input type="password" id="cp_new" class="form-control"
                               placeholder="Min 6 characters" />
                        <div id="cp_new_error" class="text-danger small"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Confirm Password <span class="text-danger">*</span></label>
                        <input type="password" id="cp_confirm" class="form-control" />
                        <div id="cp_confirm_error" class="text-danger small"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-warning" onclick="submitChangePassword()">
                        Change Password
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Hiện thông tin user
        const fullName = sessionStorage.getItem('fullName');
        const role = sessionStorage.getItem('role');

        if (fullName) document.getElementById('navFullName').textContent = fullName;
        if (role) document.getElementById('dropdownRole').textContent = role;

        // Logout
        async function logout() {
            await fetch('/api/auth/logout', { method: 'POST' });
            document.cookie = 'jwt_token=; path=/; max-age=0';
            sessionStorage.clear();
            window.location.href = '/Login';
        }

        // ===== PROFILE =====
        async function openProfileModal() {
            const userId = sessionStorage.getItem('userId');
            const response = await fetch(`/api/accounts/${userId}`);
            const account = await response.json();

            // Hiện thông tin
            document.getElementById('profile_display_name').textContent = account.fullName;
            document.getElementById('profile_display_username').textContent = '@@' + account.username;
            document.getElementById('profile_display_role').innerHTML =
                `<span class="badge bg-info">${getRoleName(account.role)}</span>`;
            document.getElementById('profile_display_status').innerHTML =
                account.status === 0
                    ? '<span class="badge bg-success">Active</span>'
                    : '<span class="badge bg-secondary">Inactive</span>';

            // Fill form
            document.getElementById('profile_fullName').value = account.fullName;
            document.getElementById('profile_email').value = account.email;
            document.getElementById('profile_phone').value = account.phone || '';
            document.getElementById('profile_fullName_error').textContent = '';
            document.getElementById('profile_email_error').textContent = '';
            document.getElementById('profileAlert').classList.add('d-none');

            new bootstrap.Modal(document.getElementById('profileModal')).show();
        }

        async function submitEditProfile() {
            const fullName = document.getElementById('profile_fullName').value.trim();
            const email = document.getElementById('profile_email').value.trim();
            const phone = document.getElementById('profile_phone').value.trim();

            let isValid = true;
            if (!fullName) {
                document.getElementById('profile_fullName_error').textContent = 'Full name is required';
                isValid = false;
            } else {
                document.getElementById('profile_fullName_error').textContent = '';
            }

            if (!email) {
                document.getElementById('profile_email_error').textContent = 'Email is required';
                isValid = false;
            } else {
                document.getElementById('profile_email_error').textContent = '';
            }

            if (!isValid) return;

            const response = await fetch('/api/auth/edit-profile', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ fullName, email, phone })
            });

            const result = await response.json();
            const alertBox = document.getElementById('profileAlert');

            if (response.ok) {
                sessionStorage.setItem('fullName', fullName);
                document.getElementById('navFullName').textContent = fullName;
                document.getElementById('profile_display_name').textContent = fullName;

                alertBox.className = 'alert alert-success';
                alertBox.textContent = result.message;
                alertBox.classList.remove('d-none');
                setTimeout(() => {
                    bootstrap.Modal.getInstance(
                        document.getElementById('profileModal')).hide();
                }, 1500);
            } else {
                alertBox.className = 'alert alert-danger';
                alertBox.textContent = result.message;
                alertBox.classList.remove('d-none');
            }
        }

        // ===== CHANGE PASSWORD =====
        function openChangePasswordModal() {
            document.getElementById('cp_current').value = '';
            document.getElementById('cp_new').value = '';
            document.getElementById('cp_confirm').value = '';
            ['current', 'new', 'confirm'].forEach(f => {
                document.getElementById(`cp_${f}_error`).textContent = '';
            });
            document.getElementById('changePassAlert').classList.add('d-none');
            new bootstrap.Modal(document.getElementById('changePasswordModal')).show();
        }

        async function submitChangePassword() {
            const currentPassword = document.getElementById('cp_current').value.trim();
            const newPassword = document.getElementById('cp_new').value.trim();
            const confirmPassword = document.getElementById('cp_confirm').value.trim();

            let isValid = true;

            if (!currentPassword) {
                document.getElementById('cp_current_error').textContent = 'Current password is required';
                isValid = false;
            } else {
                document.getElementById('cp_current_error').textContent = '';
            }

            if (!newPassword || newPassword.length < 6) {
                document.getElementById('cp_new_error').textContent = 'Password must be at least 6 characters';
                isValid = false;
            } else {
                document.getElementById('cp_new_error').textContent = '';
            }

            if (!confirmPassword) {
                document.getElementById('cp_confirm_error').textContent = 'Please confirm your password';
                isValid = false;
            } else if (newPassword !== confirmPassword) {
                document.getElementById('cp_confirm_error').textContent = 'Passwords do not match';
                isValid = false;
            } else {
                document.getElementById('cp_confirm_error').textContent = '';
            }

            if (!isValid) return;

            const response = await fetch('/api/auth/change-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ currentPassword, newPassword, confirmPassword })
            });

            const result = await response.json();
            const alertBox = document.getElementById('changePassAlert');

            if (response.ok) {
                alertBox.className = 'alert alert-success';
                alertBox.textContent = result.message;
                alertBox.classList.remove('d-none');
                setTimeout(() => {
                    bootstrap.Modal.getInstance(
                        document.getElementById('changePasswordModal')).hide();
                }, 1500);
            } else {
                alertBox.className = 'alert alert-danger';
                alertBox.textContent = result.message;
                alertBox.classList.remove('d-none');
            }
        }

        // ===== HELPERS =====
        function getRoleName(role) {
            const roles = ['Admin', 'HotelManager', 'Receptionist', 'RoomStaff'];
            return roles[role] || 'Unknown';
        }
    </script>
</body>
</html>