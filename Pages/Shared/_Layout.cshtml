<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hotel System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Hotel_System.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-page="/Index">
                    <i class="bi bi-building"></i> Hotel System
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">

                        @* Menu Admin *@
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-page="/Admin/Accounts">
                                <i class="bi bi-people"></i> Accounts
                            </a>
                        </li>

                        @* Menu Hotel Manager *@
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-page="/Manager/RoomTypes">
                                <i class="bi bi-door-closed"></i> Room Types
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-white" asp-page="/Manager/Rooms">
                                <i class="bi bi-door-open"></i> Rooms
                            </a>
                        </li>

                        @* Hotel Infor *@
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-page="/Admin/HotelInfo">
                                <i class="bi bi-building-gear"></i> Hotel Info
                            </a>
                        </li>

                        @* Service *@
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-page="/Manager/Services">
                                <i class="bi bi-gear"></i> Services
                            </a>
                        </li>

                        @* Task *@
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-page="/Manager/Tasks">
                                <i class="bi bi-clipboard-check"></i> Tasks
                            </a>
                        </li>

                    </ul>

                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link text-white" href="#">
                                <i class="bi bi-person-circle"></i> Admin
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" href="#">
                                <i class="bi bi-box-arrow-right"></i> Logout
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container">
            &copy; 2026 - Hotel System
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>