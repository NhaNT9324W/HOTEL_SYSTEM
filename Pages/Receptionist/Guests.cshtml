@page
@model Hotel_System.Pages.Receptionist.GuestsModel
@{
    ViewData["Title"] = "Quản lý khách hàng";
}

<h2>Quản lý khách hàng</h2>

<input type="text" id="searchBox" class="form-control mb-3" placeholder="Tìm theo tên, SĐT, email..." />
<button class="btn btn-primary mb-3" onclick="openCreateForm()">+ Thêm khách hàng</button>

<table class="table table-hover" id="guestTable">
    <thead>
        <tr><th>Họ tên</th><th>SĐT</th></tr>
    </thead>
    <tbody><!-- render bằng JS --></tbody>
</table>

<div id="detailCard" class="card" style="display:none; position:fixed; top:10%; left:30%; width:40%; z-index:999;">
    <div class="card-body" id="detailCardBody"></div>
</div>

<!--  file Guests.cshtml và sửa dòng dưới cùng : -->
@section Scripts {
    <script src="~/js/guest.js" asp-append-version="true"></script>
}